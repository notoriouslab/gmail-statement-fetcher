# ── Authentication method ─────────────────────────────────────────────────────
# Choose: imap  (App Password, headless-friendly)
#         oauth (gmail.readonly scope, more secure)
AUTH_METHOD=imap

# ── IMAP mode ─────────────────────────────────────────────────────────────────
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx   # Google Account → Security → App Passwords

# ── OAuth mode ────────────────────────────────────────────────────────────────
# OAUTH_CREDENTIALS=./credentials.json   # Download from GCP Console
# OAUTH_TOKEN=./token.json               # Auto-generated on first run — PERSIST THIS FILE

# ── Per-bank PDF / ZIP passwords ──────────────────────────────────────────────
# Format: {BANK_KEY_UPPERCASED}_{PDF_PASSWORD or ZIP_PASSWORD}
# Bank key = the key used in config.json banks section, uppercased.
# These take precedence over pdf_password / zip_password in config.json.
# Keep config.json password fields empty when using env vars here.
#
# SINOPAC_PDF_PASSWORD=your-sinopac-pdf-password
# CTBC_ZIP_PASSWORD=your-ctbc-zip-password
# ESUN_PDF_PASSWORD=your-esun-pdf-password
