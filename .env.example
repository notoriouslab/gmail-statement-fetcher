# ── Authentication method ─────────────────────────────────────────────────────
# Choose: imap  (App Password, headless-friendly)
#         oauth (gmail.readonly scope, more secure)
AUTH_METHOD=imap

# ── IMAP mode ─────────────────────────────────────────────────────────────────
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx   # Google Account → Security → App Passwords

# ── OAuth mode ────────────────────────────────────────────────────────────────
# OAUTH_CREDENTIALS=./credentials.json   # Download from GCP Console
# OAUTH_TOKEN=./token.json               # Auto-generated on first run — PERSIST THIS FILE
